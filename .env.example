# Copy to .env.local and fill in. The site renders from local seed content
# until these are set, then reads from your Sanity project.

# --- Sanity (public, safe to expose to the browser) ---------------------------
# Find these at https://www.sanity.io/manage after creating a project,
# or run `npx sanity@latest init` in this repo.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01

# --- Sanity write token (server only, never commit) ---------------------------
# Needed only for `npm run seed`. Create an "Editor" token under
# Project > API > Tokens at sanity.io/manage.
SANITY_API_WRITE_TOKEN=

# --- Deploying to Vercel ------------------------------------------------------
# Set the three NEXT_PUBLIC_SANITY_* values above in your Vercel project's
# Environment Variables (Project Settings > Environment Variables). The write
# token is only used locally for seeding and does not need to be on Vercel.
